{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "jsx-runtime",
    "types": ["bun", "node", "vite/client"],
    "paths": {
      "client": ["./core/client.ts"],
      "server": ["./core/server.ts"],
      "desktop": ["./core/desktop.ts"],
      "db": ["./core/db.ts"],
      "jsx-runtime/jsx-runtime": ["./core/client/runtime/logic/jsx-runtime.ts"],
      "jsx-runtime/jsx-dev-runtime": ["./core/client/runtime/logic/jsx-dev-runtime.ts"],
      "svg-icon-jsx/jsx-runtime": ["./core/client/runtime/tag/tags/icon/svg-jsx-runtime.ts"],
      "svg-icon-jsx/jsx-dev-runtime": ["./core/client/runtime/tag/tags/icon/svg-jsx-runtime.ts"],
    },
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "build"],
}
